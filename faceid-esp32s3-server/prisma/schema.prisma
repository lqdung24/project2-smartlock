generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model House {
  id     Int      @id @default(autoincrement())
  name   String
  users  User[]
  device Device[]
}

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  name          String?
  password      String
  role          Role         @default(OWNER)
  houseId       Int?
  house         House?       @relation(fields: [houseId], references: [id], onDelete: SetNull)
  refreshTokens User_Token[]

  enrolFaces FaceData[] @relation("user_face")

  userLocks User_Lock[] @relation("user_lock")
}

model User_Token {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String
  expireTime   DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id          Int         @id @default(autoincrement())
  name        String
  hardwareId  String      @unique
  mqttToken   String
  tokenExpiry DateTime
  houseId     Int
  house       House       @relation(fields: [houseId], references: [id], onDelete: Cascade)
  status      Status      @default(ACTIVE)
  userLocks   User_Lock[] @relation("user_lock_v2")
  deviceLogs  DeviceLog[] @relation("device_log_device")
}

enum Role {
  OWNER
  MEMBER
}

enum Status {
  ACTIVE
  DELETED
}

model FaceData {
  id       Int      @id @default(autoincrement())
  label    String
  img_url  String
  userId   Int
  createAt DateTime @default(now())

  user        User        @relation("user_face", fields: [userId], references: [id])
  embedVector Bytes?
  status      Status      @default(ACTIVE)
  deviceLogs  DeviceLog[] @relation("device_log_user")
}

model User_Lock {
  id     Int @id @default(autoincrement())
  userId Int
  lockId Int

  user   User   @relation("user_lock", fields: [userId], references: [id])
  device Device @relation("user_lock_v2", fields: [lockId], references: [id])
}

enum Source {
  APP
  FACEID
}

model DeviceLog {
  id       Int      @id @default(autoincrement())
  deviceId Int
  time     DateTime
  faceid   Int?
  source   Source   @default(FACEID)

  face   FaceData? @relation("device_log_user", fields: [faceid], references: [id])
  device Device    @relation("device_log_device", fields: [deviceId], references: [id])
}
